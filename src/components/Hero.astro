---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}
const { eyebrow, title, lead } = Astro.props;
---
<header class="hero">
  <div class="hero-inner">
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
    <h1>{title}</h1>
    {lead && <p class="hero-lead">{lead}</p>}
    <slot />
  </div>
</header>
