  {
    name: 'Teya S. Bergamaschi',
    affil: 'MIT',
    role: 'Outreach Chair',
    photo: 'people/teya.jpg',
    web: 'https://teyaberg.github.io/',
  },
  {
    name: 'Frances Dean',
    affil: 'UC Berkeley & UCSF',
    role: 'Outreach',
    photo: 'people/frances.jpg',
    web: 'https://frances-dean.github.io/',
  },
];

function initials(name: string) {
  return name.split(' ').filter(Boolean).map(w => w[0]).slice(0, 2).join('');
}
---
<BaseLayout title="Organizing Committee">
  <Hero
    eyebrow="About · Organizing Committee"
    title="Organizing Committee"
    lead="The team behind ML4H 2026."
  />

  <section class="section">
    <div class="wrap wrap--wide">
      <div class="people-grid people-grid--profiles">
        {committee.map((person) => (
          <div class="profile-card">
            <div class="profile-thumb">
              {person.photo
                ? <img src={`${base}${person.photo}`} alt={person.name} loading="lazy" />
                : <div class="profile-thumb-initials">{initials(person.name)}</div>
              }
            </div>
            <div class="profile-card-body">
              {person.web
                ? <a href={person.web} class="profile-card-link" target="_blank" rel="noopener">
                    <h3>{person.name}</h3>
                  </a>
                : <h3>{person.name}</h3>
              }
              <p class="profile-card-tagline">{person.role}</p>
              {person.affil && <p class="profile-card-affil">{person.affil}</p>}
            </div>
          </div>
        ))}
      </div>

      <div class="btn-row" style="margin-top:2rem">
        <a class="btn btn-outline" href={url('about')}>Back to About</a>
      </div>
    </div>
  </section>
</BaseLayout>
