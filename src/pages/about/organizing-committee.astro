    affil: 'University of Toronto, Vector Institute',
    role: 'Workflow Chair',
    photo: 'people/jerry.jpg',
    web: 'https://jerryji007.github.io',
  },
  {
    name: 'Yupeng Zhang',
    affil: 'The University of Sydney',
    role: 'Logistics Chair',
    photo: 'people/yupeng.jpg',
    web: 'https://ypz404.github.io/',
  },
  {
    name: 'Lex (Lexuan) Shao',
    affil: 'The University of Sydney',
    role: 'Logistics Co-Chair',
    photo: 'people/lex.jpg',
    web: null,
  },
  {
    name: 'Xumou Zhang',
    affil: null,
    role: 'Logistics Co-Chair',
    photo: 'people/xumou.jpg',
    web: 'https://www.linkedin.com/in/xumouzhang/',
  },
  {
    name: 'Maxwell Xu',
    affil: 'Google',
    role: 'Finance Co-Chair',
