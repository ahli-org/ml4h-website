    photo: 'people/amin.jpg',
    web: 'https://www.adibi.ca',
  },
  {
    name: 'Sasha Ronaghi',
    affil: 'MIT',
    role: 'Communications Subchair',
    photo: 'people/sasha.jpg',
    web: 'https://www.linkedin.com/in/sasha-ronaghi/',
  },
  {
    name: 'Simon A. Lee',
    affil: 'UCLA',
