---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { url } from '../../lib/site';
---
<BaseLayout title="Speakers">
  <Hero
    eyebrow="Attend · Speakers"
    title="Invited Speakers"
    lead="ML4H 2026 will feature distinguished invited speakers from across the machine learning and health communities."
  />

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">ML4H 2026</p>
      <h2>Speaker announcements</h2>
      <p>
        Invited keynote and featured speakers will be announced here.
        ML4H consistently brings together leading researchers in machine
        learning, clinical medicine, and health informatics to share their work
        and perspectives with the community.
      </p>
      <div class="callout">
        <p>
          <strong>Speaker announcements coming soon.</strong> Follow us for updates.
        </p>
      </div>
      <div class="btn-row">
        <a class="btn btn-outline" href={url('attend/schedule')}>Program Schedule</a>
      </div>
    </div>
  </section>
</BaseLayout>
