---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';

const tiers = [
  {
    tier: 'diamond',
    label: 'Diamond',
    sponsors: [] as { name: string; url: string; logo?: string; blurb?: string }[],
  },
  {
    tier: 'gold',
    label: 'Gold',
    sponsors: [] as { name: string; url: string; logo?: string; blurb?: string }[],
  },
  {
    tier: 'silver',
    label: 'Silver',
    sponsors: [] as { name: string; url: string; logo?: string; blurb?: string }[],
  },
];

const base = import.meta.env.BASE_URL;

// Principles for a transparent and appropriate relationship with funders.
const principles = [
  'The substance and structure of the symposium are determined independently by the program committees.',
  'All papers are chosen through a rigorous, mutually anonymous peer review process, where authors disclose conflicts of interest.',
  'All sources of financial support are acknowledged.',
  'Benefits are publicly disclosed below.',
  'Corporate sponsors cannot specify how contributions are spent.',
];

// 2026 sponsorship levels. Benefit items carry inline <strong> emphasis and are
// rendered with set:html, so keep the markup here trusted/static.
const levels = [
  {
    tier: 'diamond',
    name: 'Diamond Sponsor',
    price: '$20,000 USD',
    slots: 'Two (2) slots available',
    reg: 'Free registration for up to <strong>10</strong> representatives from your organization',
    groups: [
      {
        label: 'Branding',
        items: [
          'Company name listed as <strong>&ldquo;ML4H presented by [company]&rdquo;</strong> on website header',
          'Primary placement of company logo on name badges',
          'Company logo displayed on website and promotional materials',
        ],
      },
      {
        label: 'Presentation and Exhibits',
        items: [
          "Present a <strong>20-minute lunch talk</strong> on company's work in machine learning and health research or development or lead a 45-minute research roundtable",
          'Dedicated <strong>booth</strong> (6 ft table or equivalent) throughout the conference',
        ],
      },
      {
        label: 'Verbal Recognitions',
        items: [
          '<strong>Exclusive acknowledgment</strong> to attendees before start of lunch break',
          '<strong>Verbal acknowledgment</strong> of contribution in the opening and closing remarks of the conference and before lunch break',
        ],
      },
      {
        label: 'Access to Talent',
        items: [
          'Access to attendee <strong>information</strong> such as name, email, job title, of those who opt-in for career opportunities',
          'Free posting on AHLI job board for one year',
        ],
      },
    ],
  },
  {
    tier: 'gold',
    name: 'Gold Sponsor',
    price: '$10,000 USD',
    slots: 'Five (5) slots available',
    reg: 'Free registration for up to <strong>5</strong> representatives from your organization',
    groups: [
      {
        label: 'Branding',
        items: ['Company logo displayed on website and promotional materials'],
      },
      {
        label: 'Presentations and Exhibits',
        items: ['Dedicated <strong>booth</strong> (6 ft table or equivalent) throughout the conference'],
      },
      {
        label: 'Verbal Recognitions',
        items: ['<strong>Verbal acknowledgment</strong> of contribution in the opening and closing remarks of the conference'],
      },
      {
        label: 'Access to Talent',
        items: [
          'Access to attendee <strong>information</strong> such as name, email, job title, of those who opt-in for career opportunities',
          'Free posting on AHLI job board for one year',
        ],
      },
    ],
  },
  {
    tier: 'silver',
    name: 'Silver',
    price: '$5,000 USD',
    slots: 'Unlimited slots available',
    reg: 'Free registration for up to <strong>2</strong> representatives from your organization',
    groups: [
      {
        label: 'Branding',
        items: ['Company logo displayed on website and promotional materials'],
      },
      {
        label: 'Verbal Recognition',
        items: ['<strong>Verbal acknowledgment</strong> of contribution in the opening and closing remarks of the conference'],
      },
      {
        label: 'Access to Talent',
        items: [
          'Access to attendee <strong>information</strong> such as name, email, job title, of those who opt-in for career opportunities',
          'Free posting on AHLI job board for one year',
        ],
      },
    ],
  },
  {
    tier: 'startup',
    name: 'Academy/Startup',
    price: '$2,000 USD',
    slots: 'Unlimited slots available',
    reg: 'Free registration for up to <strong>1</strong> representative from your organization',
    groups: [
      {
        label: 'Branding',
        items: ['Company logo displayed on website and promotional materials'],
      },
      {
        label: 'Access to Talent',
        items: ['Free posting on AHLI job board for one year'],
      },
    ],
  },
];

// Add-ons available to Silver-and-above sponsors.
const addOns = [
  {
    title: 'Research Roundtable (5 slots): <strong>+$2,500</strong>',
    sub: ['1&ndash;2 representative(s) at the roundtable', 'Roundtable topic is subject to approval'],
  },
  { title: 'Networking Social (3 slots): <strong>+$3,500</strong>', sub: [] },
  {
    title: 'Best Paper Award (4 slots): <strong>+$500</strong>',
    sub: ['$2k for exclusive paper award sponsor', 'Acknowledgement at presentation'],
  },
  { title: 'Best Demo Award (1 slot): <strong>+$500</strong>', sub: ['Acknowledgement at presentation'] },
  { title: 'Best Reviewer Award (1 slot): <strong>+$150</strong>', sub: ['Acknowledgement at presentation'] },
  {
    title: 'Travel Awards (unlimited slots): <strong>+$500 each</strong>',
    sub: ['$12k for exclusive travel award sponsor', 'Sponsor author travel'],
  },
];

// Bundled packages that fund multiple AHLI events.
const bundles = [
  {
    title: 'Diamond and Gold Multi-Event Package',
    sub: ['$25,000 for 2 conferences', 'Approx. 15% discount with $30,000 value'],
  },
  {
    title: 'Silver Multi-Event Discount Package',
    sub: ['$16,000 for 4 conferences', '20% discount with $20,000 value'],
  },
  {
    title: 'Gold BOGO 50% Package',
    sub: ['$15,000 for 2 conferences', '25% discount with $20,000 value', 'Buy One Get One 50% Off'],
  },
  {
    title: 'A La Carte &amp; Custom Package',
    sub: ['15% discount with flexible, tailored options combining elements from other packages'],
  },
];
---
<BaseLayout title="Sponsors">
  <Hero
    eyebrow="Sponsors"
    title="Sponsor ML4H 2026"
    lead="Sponsoring ML4H 2026 gives your organization visibility with leading researchers and practitioners in machine learning for health, and helps keep the symposium accessible to a broad set of participants."
  />

  <section class="section" id="become-a-sponsor">
    <div class="wrap">
      <p class="eyebrow">Become a Sponsor</p>
      <h2>Support ML4H 2026</h2>
      <p>
        Financial support ensures that ML4H remains accessible to a broad set of
        participants by offsetting the expenses involved in participation. If you
        are interested, please email us at
        <a href="mailto:ml4h@ahli.cc">ml4h@ahli.cc</a>. We follow best practices in
        other conferences to maintain a transparent and appropriate relationship
        with our funders:
      </p>
      <ol>
        {principles.map((p) => <li>{p}</li>)}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="wrap wrap--wide">
      <h2>2026 Sponsorship Levels</h2>
      <p>
        Sponsorship of the Machine Learning for Health (ML4H) symposium
        contributes to furthering research and interdisciplinary dialogue around
        machine learning, health, and biomedicine. We deeply appreciate any amount
        of support your company or foundation can provide.
      </p>

      <div class="tier-grid">
        {levels.map((lvl) => (
          <article class={`tier-card tier-card--${lvl.tier}`}>
            <header class="tier-head">
              <p class="tier-name">{lvl.name}</p>
              <p class="tier-price">{lvl.price}</p>
              <p class="tier-slots">{lvl.slots}</p>
            </header>
            <div class="tier-body">
              <p class="tier-reg" set:html={lvl.reg}></p>
              {lvl.groups.map((g) => (
                <div class="tier-group">
                  <h4>{g.label}</h4>
                  <ul>
                    {g.items.map((it) => <li set:html={it}></li>)}
                  </ul>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap wrap--wide">
      <h2>Add-Ons &mdash; for Silver and Above</h2>
      <ul class="addon-list">
        {addOns.map((a) => (
          <li>
            <span set:html={a.title}></span>
            {a.sub.length > 0 && (
              <ul>
                {a.sub.map((s) => <li set:html={s}></li>)}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="wrap wrap--wide">
      <h2>Bundled Packages</h2>
      <p>We have additional bundled packages to fund multiple AHLI events.</p>
      <ul class="addon-list">
        {bundles.map((b) => (
          <li>
            <span set:html={b.title}></span>
            {b.sub.length > 0 && (
              <ul>
                {b.sub.map((s) => <li set:html={s}></li>)}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Our Sponsors</p>
      <h2>With thanks to our sponsors</h2>
      <p>
        ML4H 2026 is made possible by the generous support of our sponsors. We are
        grateful for their commitment to advancing machine learning for health.
      </p>
      {tiers.map((t) => (
        <div class={`sponsor-tier sponsor-tier--${t.tier}`}>
          <div class="sponsor-tier-badge">{t.label}</div>
          {t.sponsors.length > 0 ? (
            <div class="sponsor-grid">
              {t.sponsors.map((s) => (
                <article class="sponsor-card">
                  <a href={s.url} rel="noopener" target="_blank" aria-label={s.name}>
                    {s.logo
                      ? <img class="sponsor-logo" src={`${base}${s.logo}`} alt={`${s.name} logo`} loading="lazy" />
                      : <span class="sponsor-name">{s.name}</span>}
                  </a>
                  {s.blurb && <p>{s.blurb}</p>}
                </article>
              ))}
            </div>
          ) : (
            <p class="sponsor-placeholder">Sponsor announcements coming soon.</p>
          )}
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="callout">
        <p>
          Ready to support ML4H 2026, or have questions about tiers, add-ons, and
          bundled packages? Email us at
          <a href="mailto:ml4h@ahli.cc">ml4h@ahli.cc</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .tier-grid {
    display: grid;
    gap: 1.4rem;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    margin-top: 1.8rem;
    align-items: start;
  }
  .tier-card {
    display: flex;
    flex-direction: column;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .tier-head {
    padding: 1.4rem 1.6rem 1.2rem;
    border-bottom: 1px solid var(--line);
  }
  .tier-card--diamond .tier-head { background: #e8f0ff; border-bottom-color: #c5d0f0; }
  .tier-card--gold    .tier-head { background: #fff8e0; border-bottom-color: #e0ce88; }
  .tier-card--silver  .tier-head { background: #f3f4f7; }
  .tier-card--startup .tier-head { background: #eef6ee; }
  .tier-name {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
  }
  .tier-price {
    font-family: var(--serif);
    font-size: 1.55rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0.15rem 0 0;
    line-height: 1.1;
  }
  .tier-slots {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin: 0.55rem 0 0;
  }
  .tier-body { padding: 1.3rem 1.6rem 1.6rem; }
  .tier-reg {
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 0.5rem;
  }
  .tier-reg strong { color: var(--teal); }
  .tier-group { margin-top: 1.1rem; }
  .tier-group h4 {
    font-family: var(--sans);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--teal);
    margin: 0 0 0.45rem;
  }
  .tier-group ul {
    margin: 0 0 0 1.1rem;
    padding: 0;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }
  .tier-group li { margin-bottom: 0.35rem; }
  .tier-group li:last-child { margin-bottom: 0; }

  /* Add-ons & bundled packages: bold labels with indented sub-details. */
  .addon-list { list-style: none; margin: 1.2rem 0 0; padding: 0; }
  .addon-list > li {
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }
  .addon-list > li:first-child { border-top: 1px solid var(--line); }
  .addon-list > li > span { font-weight: 600; }
  .addon-list ul {
    margin: 0.45rem 0 0 1.2rem;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }
  .addon-list ul li { margin-bottom: 0.25rem; }
</style>
