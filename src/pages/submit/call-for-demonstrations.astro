---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { url } from '../../lib/site';
---
<BaseLayout title="Call for Demonstrations">
  <Hero
    eyebrow="Submit · Call for Demonstrations"
    title="Call for Demonstrations"
    lead="Showcase a working ML4H system, tool, or prototype to the ML4H community."
  />

  <section class="section">
    <div class="wrap">
      <h2>About the demonstrations track</h2>
      <p>
        The ML4H demonstrations track provides an opportunity for researchers
        and practitioners to present working systems, interactive tools, and
        live prototypes that apply machine learning to health problems.
      </p>
      <p>
        Demonstrations complement the paper track by highlighting practical
        implementations, user interfaces, and real-world deployments that
        show ML4H methods in action.
      </p>

      <h3>What to submit</h3>
      <ul>
        <li>Interactive ML4H tools or dashboards</li>
        <li>Clinical decision support systems</li>
        <li>Data annotation or curation tools</li>
        <li>Benchmarking or evaluation frameworks</li>
        <li>Educational or explainability tools for health AI</li>
        <li>Any working prototype relevant to the ML4H community</li>
      </ul>

      <div class="callout">
        <p>
          <strong>Submission details</strong> including format, deadlines,
          and the portal link will be announced here. Check back soon.
        </p>
      </div>

      <div class="btn-row">
        <a class="btn btn-outline" href={url('submit')}>Back to Submit</a>
      </div>
    </div>
  </section>
</BaseLayout>
